# Copy this file to `.env` and fill values for local development
# Use placeholder values only. DO NOT commit real secrets to the repository.

# Server settings
PORT=5000
MONGODB_URI=mongodb://localhost:27017/devlink
CLIENT_URL=http://localhost:3000

# JWT settings
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_EXPIRE=30d

# Admin settings
ADMIN_USER=admin@example.com
ADMIN_PASS=adminpass
ADMIN_TOKEN=admintoken123

# Google OAuth (optional)
# Replace with your OAuth client ID if you enable Google Sign-In
# GOOGLE_CLIENT_ID must end with .apps.googleusercontent.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET should be kept secret and not committed
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# TURN / WebRTC (optional - recommended for production)
# Example TURN server settings. Use your provider's credentials or set these in the frontend Vite env (VITE_TURN_*).
TURN_URL=turn:turn.example.com:3478
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword

# Frontend (Vite) variables - place in frontend/.env or frontend/.env.local
# VITE_TURN_URL=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# VITE_TURN_USERNAME=turnuser
# VITE_TURN_PASSWORD=turnpassword
